{
  "vhosts": [
    { "name": "/" }
  ],
  "users": [
    { "name": "guest", "password": "guest", "tags": "administrator" }
  ],
  "permissions": [
    { "user": "guest", "vhost": "/", "configure": ".*", "write": ".*", "read": ".*" }
  ],
  "exchanges": [
    { "name": "ex.main",  "vhost": "/", "type": "direct", "durable": true, "auto_delete": false, "internal": false, "arguments": {} },
    { "name": "ex.retry", "vhost": "/", "type": "direct", "durable": true, "auto_delete": false, "internal": false, "arguments": {} },
    { "name": "ex.error", "vhost": "/", "type": "direct", "durable": true, "auto_delete": false, "internal": false, "arguments": {} }
  ],
  "queues": [
    {
      "name": "Order-Paid-Restaurant.queue",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {
        "x-dead-letter-exchange": "ex.retry",
        "x-dead-letter-routing-key": "Order-Paid-Restaurant.queue.retry.30s"
      }
    },
    {
      "name": "Order-Paid-Restaurant.queue.retry.30s",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {
        "x-message-ttl": 30000,
        "x-dead-letter-exchange": "ex.main",
        "x-dead-letter-routing-key": "Order-Paid-Restaurant.queue"
      }
    },
    {
      "name": "Order-Paid-Restaurant.queue.error",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {}
    }
  ],
  "bindings": [
    { "source": "ex.main",  "vhost": "/", "destination": "Order-Paid-Restaurant.queue",          "destination_type": "queue", "routing_key": "Order-Paid-Restaurant.queue",          "arguments": {} },
    { "source": "ex.retry", "vhost": "/", "destination": "Order-Paid-Restaurant.queue.retry.30s","destination_type": "queue", "routing_key": "Order-Paid-Restaurant.queue.retry.30s","arguments": {} },
    { "source": "ex.error", "vhost": "/", "destination": "Order-Paid-Restaurant.queue.error",    "destination_type": "queue", "routing_key": "Order-Paid-Restaurant.queue.error",    "arguments": {} }
  ]
}