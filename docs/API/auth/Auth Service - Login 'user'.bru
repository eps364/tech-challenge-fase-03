meta {
  name: Auth Service - Login 'user'
  type: http
  seq: 3
}

post {
  url: {{base_url}}/auth-service/auth/login
  body: json
  auth: none
}

body:json {
  {
    "username": "user",
    "password": "user"
  }
}

script:post-response {
  const data = res.getBody();
  
  if (data && data.accessToken) {
    bru.setEnvVar("jwt_token", data.accessToken);
  }
}
