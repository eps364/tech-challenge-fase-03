meta {
  name: 🔐 🌐 Auth Service - Login
  type: http
  seq: 1
}

post {
  url: {{base_url}}/auth-service/auth/login
  body: json
  auth: none
}

body:json {
  {
    "username": "{{username}}",
    "password": "{{password}}"
  }
}

script:post-response {
  const data = res.getBody();
  
  if (data && data.access_token) {
    bru.setEnvVar("jwt_token", data.access_token);
  }
  if (data && data.userId) {
    bru.setEnvVar("user_id", data.userId);
  }
  if (data && data.refresh_token) {
    bru.setEnvVar("refresh_token", data.refresh_token);
  }
}

example {
  name: 200
  
  request: {
    url: {{base_url}}/auth-service/auth/login
    method: POST
    mode: json
    body:json: {
      {
        "username": "{{username}}",
        "password": "{{password}}"
      }
    }
  }
  
  response: {
    headers: {
      transfer-encoding: chunked
