meta {
  name: Auth Service - Login
  type: http
  seq: 2
}

post {
  url: {{base_url}}/auth-service/auth/login
  body: json
  auth: none
}

body:json {
  {
    "username": "{{username}}",
    "password": "{{password}}"
  }
}

script:post-response {
  const data = res.getBody();
  
  if (data && data.accessToken) {
    bru.setEnvVar("jwt_token", data.accessToken);
  }
}
