meta {
  name: 🛡️ 🌐 Auth Service - Token System
  type: http
  seq: 9
}

post {
  url: http://localhost:8080/realms/tech-challenge/protocol/openid-connect/token
  body: formUrlEncoded
  auth: inherit
}

headers {
  Content-Type: application/x-www-form-urlencoded
}

body:form-urlencoded {
  grant_type: client_credentials
  client_id: orchestrator-service
  client_secret: orchestrator-service-secret
}

settings {
  encodeUrl: false
  timeout: 0
}
