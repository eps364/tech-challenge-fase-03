meta {
  name: 💳 🙋 Payment Service - Create Payment
  type: http
  seq: 1
}

post {
  url: {{base_url}}/payment-service/payments
  body: json
  auth: bearer
}

auth:bearer {
  token: {{jwt_token}}
}

body:json {
  {
    "orderId": "{{order_id}}",
    "paymentMethod": "credit_card",
    "amount": 99.90
  }
}

docs {
  Processa pagamento de pedido. Requer autenticação JWT.
}