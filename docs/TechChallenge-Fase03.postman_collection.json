    {
      "name": "🔐 🌐 Auth Service - Register",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\",\n  \"email\": \"user50@example.com\",\n  \"firstName\": \"Novo\",\n  \"lastName\": \"Usuario\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/auth-service/auth/register",
          "host": ["{{base_url}}"],
          "path": ["auth-service", "auth", "register"]
        }
      }
    },
    {
      "name": "🔐 🌐 Auth Service - Login",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/auth-service/auth/login",
          "host": ["{{base_url}}"],
          "path": ["auth-service", "auth", "login"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var data = pm.response.json();",
              "if (data.access_token) pm.collectionVariables.set('jwt_token', data.access_token);",
              "if (data.userId) pm.collectionVariables.set('user_id', data.userId);",
              "if (data.refresh_token) pm.collectionVariables.set('refresh_token', data.refresh_token);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
