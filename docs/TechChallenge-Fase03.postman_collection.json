        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"jose5\",\n  \"password\": \"jose5\",\n  \"email\": \"jose5@example.com\",\n  \"firstName\": \"Jose\",\n  \"lastName\": \"da Silva\"\n}"
        },
