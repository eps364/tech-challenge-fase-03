    {
      "name": "🔐 🌐 Auth Service - Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var data = pm.response.json();",
              "if (data.access_token) pm.collectionVariables.set('jwt_token', data.access_token);",
              "if (data.userId) pm.collectionVariables.set('user_id', data.userId);",
              "if (data.refresh_token) pm.collectionVariables.set('refresh_token', data.refresh_token);",
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Response has access_token', function () {",
              "    pm.expect(data).to.have.property('access_token');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
