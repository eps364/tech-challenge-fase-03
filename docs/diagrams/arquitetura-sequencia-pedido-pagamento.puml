@startuml
title Tech Challenge Fase 03 - Sequência de Pedido e Pagamento (Eventos + Resiliência)

actor Cliente
participant "API Gateway\n:8761" as APIGW
participant "Service Registry\nEureka :8762" as EUREKA
participant "Order Service" as ORDER
database "Order DB\nPostgres" as ORDERDB
participant "Restaurant Service" as REST
database "Restaurant DB\nPostgres" as RESTDB
participant "Payment Service" as PAY
database "Payment DB\nPostgres" as PAYDB
participant "ProcPag\n:8089" as PROCPAG
queue "RabbitMQ\n:5672" as BROKER
participant "Orchestrator Service" as ORQ
participant "Payment Worker\n(reprocessamento)" as WORKER

== Criação do pedido (Orquestrada) ==
Cliente -> APIGW: POST /orchestrator/requests (Bearer JWT)
APIGW -> EUREKA: resolve orchestrator-service
APIGW -> ORQ: inicia orquestração
ORQ -> REST: valida restaurante/itens
REST --> ORQ: validação OK
ORQ -> ORDER: cria pedido (/orders/orchestrated)
ORDER -> ORDERDB: persiste pedido inicial

== Evento de criação ==
ORDER -> BROKER: publica ORDER_CREATED (Kafka topic: orders-created)
PAY -> BROKER: consome ORDER_CREATED

== Processamento assíncrono de pagamento ==
PAY -> PAYDB: cria transação local

group Resiliência (Retry + Timeout + Circuit Breaker)
PAY -> PROCPAG: processa cobrança
end

alt pagamento autorizado
	PROCPAG --> PAY: autorizado
	PAY -> PAYDB: atualiza transação = PAGO
	PAY -> BROKER: publica PAYMENT_APPROVED\n(Kafka topic: payment-status)
	ORDER -> BROKER: consome PAYMENT_APPROVED
	ORDER -> ORDERDB: atualiza pedido = PAGO
	ORDER --> APIGW: pedido atualizado
	APIGW --> Cliente: status final = PAGO
else falha/timeout/circuito aberto
	PROCPAG --> PAY: erro / indisponível
	PAY -> PAYDB: atualiza transação = PENDENTE
	PAY -> BROKER: publica PAYMENT_PENDING\n(Kafka topic: payment-status)
	ORDER -> BROKER: consome PAYMENT_PENDING
	ORDER -> ORDERDB: atualiza pedido = PENDENTE_PAGAMENTO
	ORDER --> APIGW: pedido aceito com pendência
	APIGW --> Cliente: status = PENDENTE_PAGAMENTO

	== Reprocessamento automático ==
	WORKER -> BROKER: consome pendências (interno ao Payment Service)
	WORKER -> PROCPAG: tenta novamente cobrança
	PROCPAG --> WORKER: autorizado
	WORKER -> BROKER: publica PAYMENT_APPROVED\n(Kafka topic: payment-status)
	ORDER -> BROKER: consome PAYMENT_APPROVED
	ORDER -> ORDERDB: atualiza pedido = PAGO
end

@enduml
